# Server-side (Vercel / Node runtime)
# Cache TTL for /api/markets in milliseconds
MARKETS_CACHE_TTL_MS=60000

# Official protocol adapters (set to real production endpoints)
BERADROME_MARKETS_API_URL=
ARBERA_MARKETS_API_URL=
KODIAK_MARKETS_API_URL=

# Server debug logging (set 1 temporarily when debugging)
DEBUG_MARKETS=0

# Client-side debug logging (Vite env; set 1 temporarily)
VITE_DEBUG_MARKETS=0
